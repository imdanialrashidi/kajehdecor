---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SERVICES, getServiceBySlug } from '../../data/services';
import { PROJECTS } from '../../data/projects';
import { SITE } from '../../data/site';

export function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const relatedProjects = PROJECTS.filter((p) =>
  service.slug.includes('kitchen') ? p.category === 'kitchen' :
  service.slug.includes('renovation') ? p.category === 'renovation' :
  service.slug.includes('commercial') ? p.category === 'office' || p.category === 'commercial' :
  p.category === 'residential'
).slice(0, 3);
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDesc}
>
  <script is:inline type="application/ld+json" slot="head">
  {JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": service.title,
    "description": service.shortDesc,
    "provider": {
      "@type": "LocalBusiness",
      "name": SITE.name,
      "telephone": "+989934202034"
    },
    "areaServed": SITE.serviceAreas
  })}
  </script>

  <script is:inline type="application/ld+json" slot="head">
  {JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": service.faqs.map((faq) => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a
      }
    }))
  })}
  </script>

  <!-- Hero -->
  <section class="page-hero section section--alt">
    <div class="container">
      <nav class="breadcrumb" aria-label="مسیر راهنما">
        <ol>
          <li><a href="/">خانه</a></li>
          <li><a href="/services/">خدمات</a></li>
          <li aria-current="page">{service.title}</li>
        </ol>
      </nav>
      <span class="page-hero__icon" aria-hidden="true">{service.icon}</span>
      <h1>{service.title}</h1>
      <p class="page-hero__subtitle">{service.shortDesc}</p>
      <div class="page-hero__actions">
        <a href="/consultation/" class="btn btn--primary btn--lg">درخواست مشاوره رایگان</a>
        <a href={SITE.social.whatsapp} class="btn btn--whatsapp btn--lg" target="_blank" rel="noopener noreferrer">
          ارسال پیام در واتساپ
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section">
    <div class="container">
      <h2>این خدمت شامل چه مواردی می‌شود؟</h2>
      <div class="feature-grid">
        {service.features.map((f) => (
          <div class="feature-item">
            <span class="feature-item__check" aria-hidden="true">✓</span>
            <span>{f}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Suitable For -->
  <section class="section section--alt">
    <div class="container">
      <h2>مناسب چه کسانی است؟</h2>
      <ul class="suitable-list">
        {service.suitableFor.map((s) => <li>{s}</li>)}
      </ul>
    </div>
  </section>

  <!-- Process -->
  <section class="section">
    <div class="container">
      <h2>مراحل اجرا</h2>
      <div class="process-steps">
        {service.process.map((step, i) => (
          <div class="process-step">
            <span class="process-step__num">{i + 1}</span>
            <span class="process-step__text">{step}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Deliverables -->
  <section class="section section--alt">
    <div class="container">
      <h2>خروجی‌ها و تحویلی‌ها</h2>
      <ul class="deliverables-list">
        {service.deliverables.map((d) => <li>{d}</li>)}
      </ul>
    </div>
  </section>

  <!-- Related Projects -->
  {relatedProjects.length > 0 && (
    <section class="section">
      <div class="container">
        <h2>پروژه‌های مرتبط</h2>
        <div class="related-grid">
          {relatedProjects.map((p) => (
            <article class="card">
              <div class="card__image">
                <img src={`/images/projects/${p.slug}.svg`} alt={p.title} width="800" height="600" loading="lazy" class="project-card__img" />
              </div>
              <div class="card__body">
                <h3><a href={`/portfolio/${p.slug}/`}>{p.title}</a></h3>
                <p class="text-muted" style="font-size:var(--text-sm)">{p.location} · {p.type}</p>
                <a href={`/portfolio/${p.slug}/`} class="btn btn--ghost btn--sm">مشاهده ←</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container container--narrow">
      <h2 class="text-center">سؤالات متداول</h2>
      <div class="faq-list">
        {service.faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-item__q">{faq.q}</summary>
            <p class="faq-item__a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark text-center">
    <div class="container">
      <h2>آماده شروع هستید؟</h2>
      <p style="color:var(--color-sand);max-width:50ch;margin-inline:auto;margin-bottom:var(--space-6);">
        همین الان درخواست مشاوره ثبت کنید یا از طریق واتساپ با ما در ارتباط باشید.
      </p>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:var(--space-4);">
        <a href="/consultation/" class="btn btn--primary btn--lg">دریافت مشاوره رایگان</a>
        <a href={SITE.social.whatsapp} class="btn btn--whatsapp btn--lg" target="_blank" rel="noopener noreferrer">واتساپ</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    padding: 0;
  }
  .breadcrumb li:not(:last-child)::after {
    content: ' / ';
    margin-right: var(--space-2);
  }
  .breadcrumb a {
    color: var(--color-accent);
  }

  .page-hero__icon {
    font-size: var(--text-5xl);
    display: block;
    margin-bottom: var(--space-4);
  }
  .page-hero h1 { margin-bottom: var(--space-4); }
  .page-hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-bottom: var(--space-8);
  }
  .page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-bg-card);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
    font-size: var(--text-sm);
  }
  .feature-item__check {
    color: var(--color-success);
    font-weight: var(--weight-bold);
    flex-shrink: 0;
  }

  .suitable-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .suitable-list li {
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-card);
    border-radius: var(--radius-md);
    border-right: 3px solid var(--color-accent);
    font-size: var(--text-sm);
  }

  .process-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
  .process-step {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--color-bg-card);
    border-radius: var(--radius-md);
  }
  .process-step__num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--color-accent);
    color: #fff;
    font-weight: var(--weight-bold);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .process-step__text {
    font-size: var(--text-sm);
  }

  .deliverables-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
    gap: var(--space-3);
  }
  .deliverables-list li {
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-card);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    text-align: center;
    border: 1px solid var(--color-border-light);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: var(--space-6);
    margin-top: var(--space-6);
  }
  .related-grid h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }
  .related-grid h3 a { color: var(--color-text); }
  .related-grid h3 a:hover { color: var(--color-accent); }
  .project-placeholder {
    width: 100%;
    height: 100%;
    min-height: 140px;
    background: linear-gradient(135deg, var(--color-beige), var(--color-stone));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    color: var(--color-wood);
  }

  .project-card__img {
    width: 100%;
    height: 100%;
    min-height: 140px;
    object-fit: cover;
    display: block;
  }

  .faq-list {
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .faq-item {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }
  .faq-item__q {
    font-weight: var(--weight-semibold);
    cursor: pointer;
    list-style: none;
  }
  .faq-item__q::before { content: '▾ '; color: var(--color-accent); }
  .faq-item[open] .faq-item__q::before { content: '▴ '; }
  .faq-item__a {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }
</style>
