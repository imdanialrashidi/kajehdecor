---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SERVICES } from '../../data/services';
import { SITE } from '../../data/site';
import { GENERAL_FAQS } from '../../data/faq';

const process = [
  { num: '۱', title: 'مشاوره رایگان', desc: 'نیازها و بودجه‌تان را بررسی می‌کنیم.' },
  { num: '۲', title: 'بازدید و اندازه‌گیری', desc: 'از فضای شما بازدید و اندازه‌گیری دقیق انجام می‌شود.' },
  { num: '۳', title: 'طراحی سهبعدی', desc: 'طرح سهبعدی واقع‌گرایانه ارائه می‌شود.' },
  { num: '۴', title: 'اجرا و تحویل', desc: 'اجرای مرحله‌به‌مرحله با نظارت کامل.' },
];
---

<BaseLayout
  title="خدمات کاژه دکور | طراحی و اجرای دکوراسیون داخلی"
  description="آشنایی با خدمات کاژه دکور: طراحی آشپزخانه، طراحی داخلی، بازسازی، طراحی اداری و تجاری با طراحی سهبعدی و مشاوره تخصصی."
>
  <script is:inline type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "خدمات کاژه دکور",
    "description": "طراحی آشپزخانه، طراحی داخلی، بازسازی و طراحی اداری و تجاری"
  }
  </script>

  <section class="page-hero section section--alt">
    <div class="container">
      <h1>خدمات کاژه دکور</h1>
      <p class="page-hero__subtitle">
        از مشاوره اولیه تا اجرای کامل، {SITE.name} تمام مراحل طراحی و اجرای دکوراسیون داخلی را با کیفیت بالا انجام می‌دهد.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-list">
        {SERVICES.map((service) => (
          <article class="service-detail card">
            <div class="card__body">
              <span class="service-detail__icon" aria-hidden="true">{service.icon}</span>
              <h2>
                <a href={`/services/${service.slug}/`}>{service.title}</a>
              </h2>
              <p>{service.shortDesc}</p>
              <h3>شامل چه خدماتی می‌شود؟</h3>
              <ul>
                {service.features.map((f) => <li>{f}</li>)}
              </ul>
              <h3>مناسب چه کسانی است؟</h3>
              <ul>
                {service.suitableFor.map((s) => <li>{s}</li>)}
              </ul>
              <a href={`/services/${service.slug}/`} class="btn btn--primary">
                جزئیات بیشتر و مشاوره ←
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <h2 class="text-center">روند اجرای پروژه</h2>
      <div class="process-grid">
        {process.map((step) => (
          <div class="process-card text-center">
            <span class="process-card__num">{step.num}</span>
            <h3>{step.title}</h3>
            <p class="text-muted">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <h2 class="text-center">سؤالات متداول</h2>
      <div class="faq-list">
        {GENERAL_FAQS.map((faq) => (
          <details class="faq-item">
            <summary class="faq-item__q">{faq.question}</summary>
            <p class="faq-item__a">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark text-center">
    <div class="container">
      <h2>آماده شروع پروژه هستید؟</h2>
      <p class="text-muted" style="max-width:50ch;margin-inline:auto;margin-bottom:var(--space-6);">
        همین الان درخواست مشاوره رایگان ثبت کنید تا کارشناسان ما با شما تماس بگیرند.
      </p>
      <a href="/consultation/" class="btn btn--primary btn--lg">دریافت مشاوره رایگان</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero h1 {
    margin-bottom: var(--space-4);
  }
  .page-hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .service-detail__icon {
    font-size: var(--text-4xl);
    display: block;
    margin-bottom: var(--space-3);
  }

  .service-detail h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
  }
  .service-detail h2 a { color: var(--color-text); }
  .service-detail h2 a:hover { color: var(--color-accent); }

  .service-detail h3 {
    font-size: var(--text-lg);
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
  }

  .service-detail ul {
    list-style: none;
    padding: 0;
  }
  .service-detail ul li {
    padding: var(--space-1) 0 var(--space-1) var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-light);
    position: relative;
  }
  .service-detail ul li::before {
    content: '✓';
    position: absolute;
    right: 0;
    color: var(--color-success);
    font-weight: bold;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 200px), 1fr));
    gap: var(--space-6);
    margin-top: var(--space-8);
  }
  .process-card__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--color-accent);
    color: #fff;
    font-weight: var(--weight-bold);
    font-size: var(--text-xl);
    border-radius: 50%;
    margin-bottom: var(--space-3);
  }

  .faq-list {
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .faq-item {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }
  .faq-item__q {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    cursor: pointer;
    list-style: none;
  }
  .faq-item__q::before {
    content: '▾ ';
    color: var(--color-accent);
  }
  .faq-item[open] .faq-item__q::before {
    content: '▴ ';
  }
  .faq-item__a {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }
</style>
