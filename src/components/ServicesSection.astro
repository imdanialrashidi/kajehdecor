---
import { SERVICES } from '../data/services';
---

<section class="services-section section" id="services">
  <div class="container">
    <div class="section__header">
      <h2>خدمات کاژه دکور</h2>
      <p class="section__subtitle">از طراحی سهبعدی تا اجرای کامل، تمام نیازهای دکوراسیون داخلی شما در یکجا.</p>
    </div>

    <div class="services-section__grid">
      {SERVICES.map((service, i) => (
        <article class="service-card card fade-in" style={`animation-delay: ${i * 80}ms`}>
          <div class="card__body">
            <span class="service-card__icon" aria-hidden="true">{service.icon}</span>
            <h3 class="service-card__title">
              <a href={`/services/${service.slug}/`}>{service.title}</a>
            </h3>
            <p class="service-card__desc">{service.shortDesc}</p>
            <ul class="service-card__features">
              {service.features.slice(0, 3).map((f) => (
                <li>{f}</li>
              ))}
            </ul>
            <a href={`/services/${service.slug}/`} class="btn btn--ghost btn--sm">
              جزئیات بیشتر ←
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: var(--space-6);
  }

  .service-card__icon {
    font-size: var(--text-4xl);
    display: block;
    margin-bottom: var(--space-4);
  }

  .service-card__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .service-card__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .service-card__title a:hover {
    color: var(--color-accent);
  }

  .service-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .service-card__features {
    list-style: none;
    margin-bottom: var(--space-5);
  }

  .service-card__features li {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    padding: var(--space-1) 0;
    padding-right: var(--space-4);
    position: relative;
  }

  .service-card__features li::before {
    content: '✓';
    position: absolute;
    right: 0;
    color: var(--color-success);
    font-weight: var(--weight-bold);
  }
</style>
